# --- Required: GoHighLevel public API ---
# Create a Private Integration Token in GHL:
#   Settings -> Private Integrations -> Create New
# Give it every scope you want the CLI to use (contacts, workflows, etc).
GHL_API_KEY=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Your GHL location/sub-account ID (the long string in your GHL URL).
GHL_LOCATION_ID=YOUR_LOCATION_ID

# --- Optional / advanced: Firebase token for the UNOFFICIAL "internal API" ---
# The public GHL API can't *create* workflows, only read them. To create/update
# workflows programmatically the CLI uses GHL's unofficial internal API, which
# needs a Firebase refresh token.
#
# Most people don't need this: to provision workflows, build one in the GHL UI
# and ship it in a Snapshot (sub-accounts inherit it) — no token required. See
# the "Workflow building" section of README.md.
#
# !! THE FIREBASE REFRESH TOKEN IS YOUR ENTIRE GHL LOGIN (full account access),
#    NOT a scoped key. Use it on YOUR OWN agency account only — never a client's,
#    and never against client sub-accounts. Treat it like a password: prefer a
#    secret manager / OS keychain over leaving it at rest here. .env is gitignored;
#    never commit it.
#
# Get both values with the no-network DevTools console snippet in
# docs/get-firebase-token.md:
#   1. Open app.gohighlevel.com (logged in), open DevTools console
#   2. Paste the snippet -> it copies both values as ready-to-paste env lines
#   3. Paste them here:
GHL_FIREBASE_API_KEY=
GHL_FIREBASE_REFRESH_TOKEN=
